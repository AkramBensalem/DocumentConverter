<idea-plugin>
    <id>me.akram.bensalem.document.converter</id>
    <name>Document Converter</name>
    <vendor url="https://github.com/AkramBensalem/DocumentConverter">Akram Bensalem</vendor>
    <description><![CDATA[
    <p align="center">
      <img src="https://raw.githubusercontent.com/AkramBensalem/DocumentConverter/master/illustrations/logo.png" alt="Logo" width="128">
    </p>

    <p>A simple IntelliJ IDEA plugin for converting files into formats like Markdown and JSON.</p>

    <p align="center">
      <img src="https://raw.githubusercontent.com/AkramBensalem/DocumentConverter/master/illustrations/main.png" alt="Main Screenshot" width="420">
    </p>

    <p>You can use it to convert supported files and folders<br>from the Project view or editor.</p>

    <p><strong>Features:</strong></p>
    <ul>
      <li>Convert files and folders</li>
      <li>Export to Markdown, JSON, and other output formats</li>
      <li>Support for OCR when needed</li>
      <li>Offline conversion support</li>
    </ul>

    <p><strong>Requirements:</strong></p>
    <ul>
      <li>Online mode requires a configured <a href="https://mistral.ai/news/mistral-ocr">Mistral AI OCR</a> <a href="https://console.mistral.ai/api-keys">API key</a></li>
      <li>Offline mode requires <a href="https://github.com/microsoft/markitdown">MarkItDown</a> CLI to be installed</li>
    </ul>
    ]]></description>
    <depends>com.intellij.modules.platform</depends>
    <extensions defaultExtensionNs="com.intellij">
        <applicationConfigurable instance="me.akram.bensalem.documentconverter.settings.DocumentConverterConfigurable" id="document.converter.settings" displayName="Document Converter" parentId="tools"/>
        <notificationGroup id="DocumentConverter" displayType="BALLOON" isLogByDefault="true"/>
    </extensions>
    <actions>
        <action id="document.converter.ConvertAction" class="me.akram.bensalem.documentconverter.actions.ConvertDocumentAction" text="Convert Document" description="Convert selected document(s)">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="first"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt M"/>
        </action>
    </actions>
</idea-plugin>